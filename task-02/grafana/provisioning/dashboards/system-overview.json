{
    "title": "System Overview",
    "uid": "system-overview",
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "5s",
    "time": {
        "from": "now-15m",
        "to": "now"
    },
    "panels": [
        {
            "id": 1,
            "title": "Container Status",
            "type": "state-timeline",
            "gridPos": {
                "x": 0,
                "y": 0,
                "w": 24,
                "h": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "max by (name) ((time() - container_last_seen{name!=\"\"}) < bool 15)",
                    "legendFormat": "{{name}}",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    }
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "0": {
                                    "text": "DOWN",
                                    "color": "red"
                                },
                                "1": {
                                    "text": "UP",
                                    "color": "green"
                                }
                            }
                        }
                    ],
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "green",
                                "value": 1
                            }
                        ]
                    }
                },
                "overrides": []
            },
            "options": {
                "mergeValues": true,
                "showValue": "never",
                "alignValue": "left",
                "rowHeight": 0.9,
                "legend": {
                    "displayMode": "table",
                    "placement": "right",
                    "calcs": [
                        "last"
                    ]
                }
            }
        },
        {
            "id": 3,
            "title": "Container CPU Usage (cores)",
            "type": "timeseries",
            "gridPos": {
                "x": 0,
                "y": 8,
                "w": 12,
                "h": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "max(rate(container_cpu_usage_seconds_total{name!=\"\"}[1m])) by (name)",
                    "legendFormat": "{{name}}",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    }
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "linear",
                        "fillOpacity": 15,
                        "gradientMode": "opacity",
                        "showPoints": "always",
                        "pointSize": 5
                    },
                    "unit": "short"
                },
                "overrides": []
            }
        },
        {
            "id": 4,
            "title": "Container Memory Usage",
            "type": "timeseries",
            "gridPos": {
                "x": 12,
                "y": 8,
                "w": 12,
                "h": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "max(container_memory_usage_bytes{name!=\"\"}) by (name)",
                    "legendFormat": "{{name}}",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    }
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "linear",
                        "fillOpacity": 15,
                        "gradientMode": "opacity",
                        "showPoints": "always",
                        "pointSize": 5
                    },
                    "unit": "bytes"
                },
                "overrides": []
            }
        },
        {
            "id": 5,
            "title": "API Request Rate (by route)",
            "type": "timeseries",
            "gridPos": {
                "x": 0,
                "y": 16,
                "w": 8,
                "h": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "sum(rate(http_requests_total[1m])) by (route)",
                    "legendFormat": "{{route}}",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    }
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "linear",
                        "fillOpacity": 15,
                        "gradientMode": "opacity",
                        "showPoints": "always",
                        "pointSize": 5
                    },
                    "unit": "reqps"
                },
                "overrides": []
            }
        },
        {
            "id": 6,
            "title": "API Error Rate (4xx & 5xx, by route)",
            "type": "timeseries",
            "gridPos": {
                "x": 8,
                "y": 16,
                "w": 8,
                "h": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "sum(rate(http_requests_total{status=~\"[45]..\", route=~\"/api.*\"}[1m])) by (route, status)",
                    "legendFormat": "{{route}} - {{status}}",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    }
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "linear",
                        "fillOpacity": 15,
                        "gradientMode": "opacity",
                        "showPoints": "always",
                        "pointSize": 5
                    },
                    "unit": "reqps"
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byRegexp",
                            "options": ".* - 5.*"
                        },
                        "properties": [
                            {
                                "id": "color",
                                "value": {
                                    "fixedColor": "red",
                                    "mode": "fixed"
                                }
                            }
                        ]
                    }
                ]
            }
        },
        {
            "id": 7,
            "title": "API p95 Latency (by route)",
            "type": "timeseries",
            "gridPos": {
                "x": 16,
                "y": 16,
                "w": 8,
                "h": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
                    "legendFormat": "{{route}}",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    }
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "linear",
                        "fillOpacity": 15,
                        "gradientMode": "opacity",
                        "showPoints": "always",
                        "pointSize": 5
                    },
                    "unit": "s"
                },
                "overrides": []
            }
        },
        {
            "id": 8,
            "title": "Database Performance",
            "type": "timeseries",
            "gridPos": {
                "x": 0,
                "y": 24,
                "w": 24,
                "h": 8
            },
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "refId": "A",
                    "expr": "rate(mysql_global_status_queries[1m])",
                    "legendFormat": "queries/sec",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    }
                },
                {
                    "refId": "B",
                    "expr": "mysql_global_status_threads_connected",
                    "legendFormat": "threads connected",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    }
                },
                {
                    "refId": "C",
                    "expr": "rate(mysql_global_status_slow_queries[5m])",
                    "legendFormat": "slow queries/sec",
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    }
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "drawStyle": "line",
                        "lineInterpolation": "linear",
                        "fillOpacity": 15,
                        "gradientMode": "opacity",
                        "showPoints": "always",
                        "pointSize": 5
                    },
                    "unit": "short"
                },
                "overrides": []
            }
        }
    ]
}